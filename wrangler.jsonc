{
    "$schema": "node_modules/wrangler/config-schema.json",
    "name": "uptimeworker",
    "account_id": "5e4d29b3db4faa691c672e24b0009999",
    "keep_vars": true,
    "main": "cloudflare/worker/index.mjs",
    "compatibility_date": "2026-05-11",
    "routes": [
        {
            "pattern": "up.wgsglobal.app",
            "custom_domain": true
        }
    ],
    "assets": {
        "directory": "./dist/",
        "not_found_handling": "single-page-application",
        "binding": "ASSETS",
        "run_worker_first": ["/api/*"]
    },
    "version_metadata": {
        "binding": "CF_VERSION_METADATA"
    },
    "observability": {
        "enabled": true
    },
    "containers": [
        {
            "class_name": "MonitorRunner",
            "image": "./cloudflare/runner/Dockerfile",
            "max_instances": 3,
            "instance_type": "basic"
        }
    ],
    "durable_objects": {
        "bindings": [
            {
                "name": "RUNNER",
                "class_name": "MonitorRunner"
            }
        ]
    },
    "migrations": [
        {
            "tag": "v1",
            "new_sqlite_classes": ["MonitorRunner"]
        }
    ],
    "d1_databases": [
        {
            "binding": "DB",
            "database_name": "uptimeworker",
            "database_id": "bd08b997-f692-4356-be17-d32af87ce4f8",
            "migrations_dir": "cloudflare/migrations"
        }
    ],
    "r2_buckets": [
        {
            "binding": "ARTIFACTS",
            "bucket_name": "uptimeworker-artifacts"
        }
    ],
    "queues": {
        "producers": [
            {
                "binding": "MONITOR_QUEUE",
                "queue": "uptimeworker-monitor-checks"
            }
        ],
        "consumers": [
            {
                "queue": "uptimeworker-monitor-checks",
                "max_batch_size": 10,
                "max_batch_timeout": 5
            }
        ]
    },
    "triggers": {
        "crons": ["* * * * *"]
    },
    "vars": {
        "APP_VERSION": "1.0.0",
        "DEPLOY_MONITOR_PAUSE_SECONDS": "120",
        "TWINGATE_TUN": "on"
    }
}
